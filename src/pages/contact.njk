---
layout: base.njk
pageTitle: Contact
activePage: contact
permalink: /contact/
---

<section class="page-header">
  <div class="container">
    <h1>Contact Us</h1>
    <p>Have questions or want to get involved? We'd love to hear from you.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <h3>Get in Touch</h3>
        <p>Whether you're interested in joining the society, competing in The GH Cup, or partnering with us, reach out and we'll get back to you.</p>
        <div class="contact-links">
          <a href="{{ site.instagram }}" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            @ghpls on Instagram
          </a>
          <a href="{{ site.linkedin }}" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          {% if site.email %}
          <a href="mailto:{{ site.email }}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 6L2 7"/></svg>
            {{ site.email }}
          </a>
          {% endif %}
        </div>
      </div>
      <!--
        Spam/abuse defences on this form:
        1. netlify-honeypot "bot-field" — hidden field; bots fill it, humans don't.
        2. Input limits + type/pattern validation below — caps payload size and
           rejects malformed values in the browser (defence-in-depth; Netlify
           also validates server-side and you can turn on reCAPTCHA — see README).
        Note: the form is processed by Netlify Forms, not by any code of ours,
        so there is no injection surface in our app to sanitize.
      -->
      <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact">
        <p class="hidden" style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
        <input type="text" name="name" placeholder="Your Name" required minlength="2" maxlength="100" autocomplete="name">
        <input type="email" name="email" placeholder="Your Email" required maxlength="254" autocomplete="email">
        <select name="subject" required>
          <option value="" disabled selected>What is this about?</option>
          <option>Joining the Society</option>
          <option>The GH Cup - Competitor Inquiry</option>
          <option>The GH Cup - Judge Inquiry</option>
          <option>Sponsorship</option>
          <option>General Question</option>
        </select>
        <textarea name="message" placeholder="Your Message" required minlength="10" maxlength="2000"></textarea>
        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>
    </div>
  </div>
</section>
